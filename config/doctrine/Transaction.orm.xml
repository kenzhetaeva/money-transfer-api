<?xml version="1.0" encoding="UTF-8" ?>
<doctrine-mapping
        xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
        http://doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="App\Entity\Transaction" table="transactions">
        <id name="id" type="integer" column="id">
            <generator strategy="AUTO" />
        </id>

        <many-to-one field="fromAccount" target-entity="App\Entity\Account" inversed-by="outgoingTransactions">
            <join-column name="from_account_id" referenced-column-name="id"/>
        </many-to-one>

        <many-to-one field="toAccount" target-entity="App\Entity\Account" inversed-by="incomingTransactions">
            <join-column name="to_account_id" referenced-column-name="id"/>
        </many-to-one>

        <field name="amount" type="decimal" precision="18" scale="2" column="amount" />
        <field name="status" enum-type="App\Enum\TransactionStatusEnum" column="status" />
        <field name="type" enum-type="App\Enum\TransactionTypeEnum" column="type" />
        <field name="createdAt" type="datetime_immutable" column="created_at" />
    </entity>
</doctrine-mapping>
